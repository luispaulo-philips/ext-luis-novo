    {
        "id": "a1f4c2e8b7d94310",
        "type": "function",
        "z": "f1a2b3c4d5e6f7a8",
        "name": "Preparar Busca Verify Token",
        "func": "const q = (msg.req && msg.req.query) ? msg.req.query : {};\nmsg.hubMode = String(q['hub.mode'] || q.hub_mode || '').trim();\nmsg.hubChallenge = String(q['hub.challenge'] || q.hub_challenge || '').trim();\nmsg.verifyTokenReceived = String(q['hub.verify_token'] || q.hub_verify_token || '').trim();\nreturn msg;",
