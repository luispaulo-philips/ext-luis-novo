    {
        "id": "94ca95e4361e8692",
        "type": "function",
        "z": "f1a2b3c4d5e6f7a8",
        "name": "Verify Token",
        "func": "const extractRows = (payload) => {\n if (Array.isArray(payload)) return payload;\n if (payload && payload.select && payload.select[0] && Array.isArray(payload.select[0].resultSet)) return payload.select[0].resultSet;\n return [];\n};\n\nconst rows = extractRows(msg.payload);\nconst row = rows[0] || null;\nconst verifyToken = row ? String(row.VERIFY_TOKEN || row.verify_token || '').trim() : '';\n\nif (msg.hubMode !== 'subscribe' || !msg.verifyTokenReceived || !verifyToken) {\n msg.payload = 'Forbidden';\n msg.statusCode = 403;\n return msg;\n}\n\nif (msg.verifyTokenReceived === verifyToken) {\n msg.payload = msg.hubChallenge;\n msg.statusCode = 200;\n} else {\n msg.payload = 'Forbidden';\n msg.statusCode = 403;\n}\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
