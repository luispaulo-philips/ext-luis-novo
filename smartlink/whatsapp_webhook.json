    {
        "id": "b3d91f6a2c4e8f11",
        "type": "sql builder",
        "z": "f1a2b3c4d5e6f7a8",
        "parameters": [
            {
                "variable": "verifyTokenReceived",
                "value": "verifyTokenReceived",
                "type": "msg"
            }
        ],
        "name": "SQL: Verify Token recebido",
        "field": "topic",
        "fieldType": "msg",
        "format": "handlebars",
        "template": "select verify_token, phone_number_id\nfrom CMDKRLS_CHAT_CONFIGURACOES\nwhere verify_token = :verifyTokenReceived\norder by dt_atualizacao desc, nr_sequencia desc\nfetch first 1 rows only",
