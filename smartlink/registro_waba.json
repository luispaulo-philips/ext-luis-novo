        "type": "function",
        "z": "190488e78a421ea1",
        "name": "Validar Entrada",
        "func": "const payload = msg.payload || {};\n\nif (!payload.CD_ESTABELECIMENTO || !payload.NR_SEQUENCIA) {\n    msg.errorDetail = 'Parâmetros obrigatórios não informados: CD_ESTABELECIMENTO e NR_SEQUENCIA.';\n    return [null, null, null, null, null, msg];\n}\n\nmsg.CD_ESTABELECIMENTO = payload.CD_ESTABELECIMENTO;\nmsg.NR_SEQUENCIA = payload.NR_SEQUENCIA;\nreturn [msg, null, null, null, null, null];",
