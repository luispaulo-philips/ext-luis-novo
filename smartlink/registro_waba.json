        ],
        "name": "Buscar Configuração",
        "fieldType": "msg",
        "template": "SELECT NR_SEQUENCIA, ACCESS_TOKEN, PHONE_NUMBER_ID, VERIFICATION_CODE\nFROM CMDKRLS_CHAT_CONFIGURACOES\nWHERE CD_ESTABELECIMENTO = :CD_ESTABELECIMENTO\nAND NR_SEQUENCIA = :NR_SEQUENCIA",
        "x": 640,
        "y": 120,
        "wires": [
