        "name": "Validar Success",
        "func": "const status = Number(msg.statusCode || 0);\nconst payload = msg.payload || {};\n\nif (payload?.success === true) return msg;\nif (!payload?.error && status >= 200 && status < 300) return msg;\nif (!payload?.error && !msg.statusCode) return msg;\nreturn null;",
