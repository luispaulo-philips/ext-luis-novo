            ]
        ]
    },
    {
        "id": "2ea958cba45460f3",
        "type": "function",
        "z": "190488e78a421ea1",
        "name": "Montar Request Meta",
        "func": "const row = msg.payload?.select?.[0]?.resultSet?.[0];\n\nif (!row) {\n    msg.errorDetail = 'Configuração não encontrada para o estabelecimento e sequência informados.';\n    return [null, null, null, null, null, msg];\n}\n\nconst accessToken = String(row.ACCESS_TOKEN || '').trim();\nconst phoneNumberId = String(row.PHONE_NUMBER_ID || '').trim();\nconst verificationCode = String(row.VERIFICATION_CODE || '').trim();\n\nif (!accessToken || !phoneNumberId || !verificationCode) {\n    msg.errorDetail = 'Configuração incompleta para registro: ACCESS_TOKEN, PHONE_NUMBER_ID e VERIFICATION_CODE são obrigatórios.';\n    return [null, null, null, null, null, msg];\n}\n\nmsg.NR_SEQUENCIA = row.NR_SEQUENCIA;\nmsg.method = 'POST';\nmsg.url = `https://graph.facebook.com/v24.0/${phoneNumberId}/register`;\nmsg.headers = {\n  Authorization: `Bearer ${accessToken}`,\n  'Content-Type': 'application/json'\n};\nmsg.payload = {\n  messaging_product: 'whatsapp',\n  verification_method: 'manual',\n  pin: verificationCode\n};\n\nreturn [msg, null, null, null, null, null];",
        "outputs": 6,
